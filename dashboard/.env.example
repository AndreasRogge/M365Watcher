# Microsoft Graph App Registration (multi-tenant app)
AZURE_TENANT_ID=your-home-tenant-id
AZURE_CLIENT_ID=your-client-id
# Required when AUTH_MODE is "app" or "dual". Not needed for "user" only.
AZURE_CLIENT_SECRET=your-client-secret

# Multi-Tenant Configuration
# Comma-separated list of additional Azure AD tenant IDs whose user tokens
# are accepted for dashboard authentication. The home tenant (AZURE_TENANT_ID)
# is always accepted. These are tenants where your account is a guest.
ALLOWED_TENANT_IDS=tenant-b-id,tenant-c-id

# Tenant Registry
# File path for the tenant registry JSON file. Defaults to dashboard/data/tenants.json.
# TENANT_STORE_PATH=./data/tenants.json

# Authentication Mode
# "app"  - App credentials only (client secret required, no user login)
# "user" - User OAuth only (popup login required, no client secret needed)
# "dual" - Both modes available, user can switch in Settings (default)
AUTH_MODE=dual

# Server Configuration
PORT=3001
